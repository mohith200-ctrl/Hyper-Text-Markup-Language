<!DOCTYPE html>
<html ng-app="myApp">
<head>
    <title>AngularJS Form with CSS and Events</title>

    <!-- AngularJS CDN -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f2f2f2;
        }

        .form-container {
            width: 350px;
            margin: 50px auto;
            padding: 20px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 0 10px gray;
        }

        input {
            width: 100%;
            padding: 8px;
            margin: 8px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        button {
            width: 100%;
            padding: 10px;
            background-color: blue;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        button:hover {
            background-color: darkblue;
        }

        .message {
            margin-top: 10px;
            font-weight: bold;
            color: green;
        }

        .highlight {
            border: 2px solid red;
        }
    </style>
</head>

<body ng-controller="formController">

    <div class="form-container">
        <h2>Registration Form</h2>

        <form name="regForm">

            <input type="text" 
                   placeholder="Enter Name"
                   ng-model="user.name"
                   ng-change="nameChanged()"
                   ng-class="{'highlight': nameFocus}"
                   ng-mouseover="nameFocus=true"
                   ng-mouseleave="nameFocus=false">

            <input type="email" 
                   placeholder="Enter Email"
                   ng-model="user.email">

            <input type="password" 
                   placeholder="Enter Password"
                   ng-model="user.password">

            <button type="button" ng-click="submitForm()">Submit</button>

        </form>

        <div class="message">
            {{message}}
        </div>
    </div>

<script>
    var app = angular.module("myApp", []);

    app.controller("formController", function($scope) {

        $scope.user = {};
        $scope.message = "";

        // Event: ng-change
        $scope.nameChanged = function() {
            $scope.message = "Typing...";
        };

        // Event: ng-click
        $scope.submitForm = function() {
            if ($scope.user.name && $scope.user.email && $scope.user.password) {
                $scope.message = "Form Submitted Successfully!";
            } else {
                $scope.message = "Please fill all fields!";
            }
        };

    });
</script>

</body>
</html>
